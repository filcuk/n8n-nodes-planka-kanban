{
	"name": "n8n-nodes-planka-kanban",
	"version": "1.1.0",
	"description": "n8n community node for Planka v2 — full API coverage for boards, cards, custom fields, users, and more",
	"license": "MIT",
	"homepage": "https://github.com/filcuk/n8n-nodes-planka-v2#readme",
	"bugs": {
		"url": "https://github.com/filcuk/n8n-nodes-planka-v2/issues"
	},
	"keywords": [
		"n8n-community-node-package",
		"n8n",
		"planka",
		"kanban",
		"project-management",
		"automation"
	],
	"author": {
		"name": "filcuk",
		"url": "https://www.npmjs.com/~filcuk"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/filcuk/n8n-nodes-planka-v2.git"
	},
	"engines": {
		"node": ">=22"
	},
	"scripts": {
		"build": "n8n-node build",
		"build:watch": "tsc --watch",
		"dev": "n8n-node dev",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
		"prepublishOnly": "npm run build && npm run lint",
		"release": "n8n-node release"
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"strict": true,
		"credentials": [
			"dist/credentials/PlankaApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/Planka/Planka.node.js"
		]
	},
	"devDependencies": {
		"@n8n/node-cli": "*",
		"eslint": "9.32.0",
		"prettier": "3.6.2",
		"release-it": "^19.0.4",
		"typescript": "5.9.2"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	}
}
